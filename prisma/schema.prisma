generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}


model BlogPost {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String?  @db.Text
  content         String?  @db.Text
  featuredImage   String?  @map("featured_image")
  status          String   @default("draft") // draft, published
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model AboutContent {
  id                String  @id @default("about")
  bio               String? @db.Text
  yearsExperience   Int?    @map("years_experience")
  projectsCompleted Int?    @map("projects_completed")
  clients           Int?

  @@map("about_content")
}

model ContactInfo {
  id          String  @id @default("contact")
  email       String?
  phone       String?
  socialLinks String? @map("social_links") @db.Text

  @@map("contact_info")
}

model HomeContent {
  id           String  @id @default("home")
  heroTitle    String? @map("hero_title")
  heroSubtitle String? @map("hero_subtitle") @db.Text
  heroImage    String? @map("hero_image")
  ctaPrimary   String? @map("cta_primary")
  ctaSecondary String? @map("cta_secondary")

  @@map("home_content")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  featured    Boolean? @default(false)
  status      String?  @default("DRAFT")
  tags        String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@map("projects")
}

model Seo {
  id              String  @id @default(cuid())
  page            String  @unique
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description") @db.Text

  @@map("seo")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  icon        String?  @default("Zap")
  sortOrder   Int?     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@map("services")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String?  @default("ADMIN")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}
